{
  "name": "wizard-connector",
  "version": "0.1.0",
  "description": "Claude Code용 플러그형 커넥터 예제 (Notion / Google Drive) + 대화형 설치 마법사. npx로 설치, macOS/Windows/Linux 지원.",
  "type": "module",
  "bin": {
    "wizard-connector": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "setup": "tsx src/cli.ts setup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@notionhq/client": "^2.2.15",
    "googleapis": "^144.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
